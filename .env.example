# --- API ---
PORT=4000
CORS_ORIGIN=http://localhost:3000

# --- Database (dev) ---
DATABASE_URL=postgresql://iam:iam@localhost:5432/iam_dev?schema=public
DATABASE_URL_TEST=postgresql://iam:iam@localhost:5433/iam_test?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth (Phase 1) ---
# IMPORTANT: generate a strong secret in production (`openssl rand -hex 32`).
JWT_SECRET=change-me-in-real-env
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Assets (Phase 3) ---
# Origin a scanned QR opens (this + /assets/qr/:token). Defaults to localhost in dev.
PUBLIC_SCAN_BASE=http://localhost:3000

# --- Web ---
# Client fetches same-origin /api/*; Next proxies to API_ORIGIN (next.config.ts).
NEXT_PUBLIC_API_URL=/api
API_ORIGIN=http://localhost:4000

# --- Deployment (set these in your hosting provider's dashboard) -----------
# In production, point at the deployed counterparts:
#   DATABASE_URL   = Render/managed Postgres connection string
#   REDIS_URL      = Upstash Redis endpoint (rediss://...)
#   CORS_ORIGIN    = deployed Vercel web URL (e.g. https://iam-web.vercel.app)
#   PUBLIC_SCAN_BASE = same deployed web URL
#   API_ORIGIN     = deployed Render api URL (e.g. https://iam-api.onrender.com)
#   JWT_SECRET     = strong random value (NOT the dev placeholder)

